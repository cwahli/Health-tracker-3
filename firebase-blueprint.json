{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile settings",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "nickname": { "type": "string" },
        "photoUrl": { "type": "string" },
        "age": { "type": "integer" },
        "ethnicity": { "type": "string" },
        "weight": { "type": "number" },
        "height": { "type": "number" },
        "language": { "type": "string" }
      },
      "required": ["email", "nickname"]
    },
    "UserMeal": {
      "title": "UserMeal",
      "description": "User's current active logged meal state",
      "type": "object",
      "properties": {
        "date": { "type": "string" },
        "name": { "type": "string" },
        "composition": { "type": "string" },
        "itemsBreakdown": { "type": "array" },
        "nutrients": { "type": "object" }
      },
      "required": ["date", "name", "composition", "itemsBreakdown", "nutrients"]
    },
    "FoodLog": {
      "title": "FoodLog",
      "description": "Logged food entry",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string" },
        "name": { "type": "string" },
        "composition": { "type": "string" },
        "weightGrams": { "type": "number" },
        "quantity": { "type": "string" },
        "benefits": { "type": "string" },
        "risks": { "type": "string" },
        "healthImpact": { "type": "string" },
        "recommendation": { "type": "string" },
        "nutrients": { "type": "object" },
        "imageUrl": { "type": "string" }
      },
      "required": ["id", "date", "name", "composition", "weightGrams", "quantity", "nutrients"]
    },
    "BiomarkerHistory": {
      "title": "BiomarkerHistory",
      "description": "Logged biomarker history record",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string" },
        "biomarkers": { "type": "object" }
      },
      "required": ["id", "date", "biomarkers"]
    },
    "HealthAction": {
      "title": "HealthAction",
      "description": "Action item suggested by preventive analytics",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "task": { "type": "string" },
        "explanation": { "type": "string" },
        "priority": { "type": "string" },
        "completed": { "type": "boolean" },
        "type": { "type": "string" }
      },
      "required": ["id", "task", "explanation", "priority", "completed", "type"]
    },
    "DailyBenefit": {
      "title": "DailyBenefit",
      "description": "Suggested daily benefit",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "activity": { "type": "string" },
        "target": { "type": "string" },
        "completed": { "type": "boolean" }
      },
      "required": ["id", "activity", "target", "completed"]
    },
    "RecommendationReport": {
      "title": "RecommendationReport",
      "description": "Most recent recommendation report generated by LLM analysis",
      "type": "object",
      "properties": {
        "timestamp": { "type": "string" },
        "dailyNutrientTargets": { "type": "object" },
        "mostImportantNextStep": { "type": "string" },
        "actions": { "type": "array" },
        "dailyBenefits": { "type": "array" },
        "latestInsights": { "type": "array" },
        "healthRiskForecast": { "type": "object" }
      },
      "required": ["timestamp", "dailyNutrientTargets", "mostImportantNextStep"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "UserProfile configurations"
    },
    "/user_meals/{userId}": {
      "schema": "UserMeal",
      "description": "User current active meal state to keep trace of modifications"
    },
    "/users/{userId}/foodLogs/{foodLogId}": {
      "schema": "FoodLog",
      "description": "User food log logs"
    },
    "/users/{userId}/biomarkerHistory/{biomarkerHistoryId}": {
      "schema": "BiomarkerHistory",
      "description": "User biomarker entries"
    },
    "/users/{userId}/actions/{actionId}": {
      "schema": "HealthAction",
      "description": "User suggested action steps"
    },
    "/users/{userId}/dailyBenefits/{benefitId}": {
      "schema": "DailyBenefit",
      "description": "User suggested lifestyle daily benefits"
    },
    "/users/{userId}/reports/{reportId}": {
      "schema": "RecommendationReport",
      "description": "User preventative cardiological reports"
    }
  }
}
